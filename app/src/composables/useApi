import { ref, isRef, watch, unref } from 'vue';
import axios from 'axios';

export function useApi(url, options = {}) {
  // Isola os estados reativos dentro da instância da função para evitar conflitos de memória
  const data = ref(null);
  const error = ref(null);
  const loading = ref(false);

  // Configurações padrão extraídas das opções
  const method = options.method || 'GET';
  const immediate = options.immediate !== undefined ? options.immediate : false;

  const fetchData = async () => {
    loading.value = true;
    error.value = null;

    try {
      // Resgata o token e limpa aspas residuais comuns do localStorage
      let token = localStorage.getItem('token') || localStorage.getItem('auth_token');
      if (token) {
        token = token.replace(/"/g, '');
      }

      // Monta os cabeçalhos padrão da requisição
      const headers = {
        'Content-Type': 'application/json',
        ...(token && { 'Authorization': token.startsWith('Bearer ') ? token : `Bearer ${token}` })
      };

      // Resolve o valor da URL caso ela venha como uma propriedade computada ou ref reativa
      const urlValue = unref(url);
      const baseUrl = import.meta.env.VITE_API_URL || 'https://portfolio-api-b1ml.onrender.com';

      const response = await axios({
        url: `${baseUrl}${urlValue}`,
        method: method,
        // Se for um DELETE, garante que o corpo não envie resíduos que causem erro 400
        data: method.toUpperCase() === 'DELETE' ? null : unref(options.data),
        headers: headers
      });

      // 🟢 PROTEÇÃO CRÍTICA ANTI-NULL: Previne o estouro de SyntaxError do JSON.parse
      if (!response.data || response.data === 'null') {
        data.value = { success: true, message: 'Operação realizada sem retorno de conteúdo.' };
      } else {
        data.value = response.data;
      }

    } catch (err) {
      console.error('Erro na infraestrutura da API (useApi):', err);
      error.value = err.response?.data || err;
      // Propaga o erro para o bloco catch do componente tratá-lo se necessário
      throw error.value;
    } finally {
      loading.value = false;
    }
  };

  // Se a URL for reativa, re-executa a busca automaticamente quando o parâmetro mudar
  if (isRef(url)) {
    watch(url, () => {
      if (immediate || options.immediate) {
        fetchData();
      }
    });
  }

  // Execução imediata caso configurado (comum em listagens GET estruturadas)
  if (immediate) {
    fetchData();
  }

  // Retorna os estados isolados e o método de disparo manual
  return {
    data,
    error,
    loading,
    fetchData
  };
}