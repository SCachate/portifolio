// src/composables/useApi.js
import { ref, watch, unref } from 'vue';
import axios from 'axios';
import { useRouter } from 'vue-router'; 
import { useToast } from 'vue-toastification'; 

export function useApi(url, options = {}) {
  const data = ref(null);
  const loading = ref(true);
  const error = ref(null);
  const router = useRouter(); 
  const toast = useToast();  

  const fetchData = async () => {
    // Pegamos o valor real da URL, seja ela uma string simples ou um Ref/Computed
    const urlValue = unref(url);
    const token = localStorage.getItem('user_token');
    
    if (!urlValue) return;

    loading.value = true;
    try {
      const headers = {
        'Content-Type': 'application/json'
      };

      // 3. Só adicionamos o Authorization se NÃO for a URL de login do Google
      if (token && urlValue !== '/auth/google') {
        headers['Authorization'] = `Bearer ${token}`;
      }

      const response = await axios({
        url: `${import.meta.env.VITE_API_URL}${urlValue}`, // Corrigido para urlValue
        method: options.method || 'get',
        data: options.data || null,
        headers: headers // Passamos o objeto de headers que construímos acima
      });

      data.value = response.data;
    } catch (err) {
      error.value = err;

      // --- TRATAMENTO DE ERRO COM TOAST ---
      if (err.response && err.response.status === 401) {
        // Remove o token para evitar loops
        localStorage.removeItem('user_token');

        // EXIBE O TOAST NO LUGAR DO ALERT
        toast.error("Sua sessão expirou. Faça login novamente.", {
          timeout: 4000, // 4 segundos
          closeOnClick: true,
          pauseOnHover: true,
        });

        router.push('/login');
      } else {
          toast.warning("Ocorreu um erro na requisição.");
      }
      // ------------------------------------

      console.error("Erro na API:", err);
    } finally {
      loading.value = false;
    }
  };

  // Se a URL for reativa (Ref ou Computed), observamos as mudanças
  if (typeof url === 'function' || (url && url.value !== undefined)) {
    watch(() => unref(url), () => {
      fetchData();
    });
  }

  // Executa a primeira vez
  fetchData();

  return { data, loading, error, fetchData };
}
