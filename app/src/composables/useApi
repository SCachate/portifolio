import { ref, watch, unref } from 'vue';
import axios from 'axios';
import { useToast } from 'vue-toastification'; 

export function useApi(url, options = {}) {
  const data = ref(null);
  const loading = ref(true);
  const error = ref(null);
  const toast = useToast();  

  const fetchData = async () => {
    const urlValue = unref(url);
    const token = localStorage.getItem('user_token'); // Mantido sua chave original
    
    if (!urlValue) return;

    loading.value = true;
    try {
      // Configuramos os headers base, mas permitimos que as 'options' sobrescrevam
      const headers = {
        'Content-Type': 'application/json',
        ...options.headers
      };

      if (token && urlValue !== '/auth/google') {
        headers['Authorization'] = `Bearer ${token}`;
      }

      console.info([options.method, options.method || 'get']);

      const methodLower = (options.method || 'get').toLowerCase();

      const response = await axios({
        url: `${import.meta.env.VITE_API_URL}${urlValue}`, 
        method: options.method || 'get',
        data: methodLower === 'delete' ? {} : (options.data || null),
        headers: headers 
      });

      data.value = response.data;
    } catch (err) {
      error.value = err;

      if (err.response && err.response.status === 401) {
        localStorage.removeItem('user_token');
        toast.error("Sua sessão expirou. Faça login novamente.");
        window.location.reload();
      } else {
        toast.error(err.response?.data?.error || "Erro na requisição.");
      }
      console.error("Erro na API:", err);
    } finally {
      loading.value = false;
    }
  };

  // Mantido seu comportamento padrão original de execução imediata
  if (options.immediate !== false) {
    fetchData();
  }

  return { data, loading, error, fetchData };
}